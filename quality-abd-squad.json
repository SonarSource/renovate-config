{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "github>SonarSource/renovate-config:languages-team"
    ],
    "timezone": "Europe/Berlin",
    "rebaseWhen": "conflicted",
    "automerge": false,
    "schedule": [
        "after 9pm",
        "before 7am"
    ],
    "enabledManagers": [
        "maven",
        "github-actions",
        "regex"
    ],
    "packageRules": [
        {
            "matchPackageNames": [
                "com.sonarsource.sonarcloud.shared:*"
            ],
            "allowedVersions": "/^\\d+\\.\\d+\\.\\d+\\.\\d+$/"
        },
        {
            "matchManagers": [
                "github-actions"
            ],
            "matchPackageNames": [
                "SonarSource/**"
            ],
            "pinDigests": false,
            "versioning": "regex:^v(?<major>\\d+)$",
            "extractVersion": "^v(?<version>\\d+)",
            "groupName": "all Sonar GitHub Actions",
            "groupSlug": "all-sonar-github-actions"
        },
        {
            "matchManagers": [
                "github-actions"
            ],
            "matchPackageNames": [
                "!SonarSource/**"
            ],
            "pinDigests": true,
            "groupName": "all third-party GitHub Actions",
            "groupSlug": "all-3rd-party-github-actions"
        },
        {
            "matchManagers": [
                "maven",
                "regex"
            ],
            "excludePackagePatterns": [
                "^org\\.sonarsource\\.api\\.plugin:sonar-plugin-api"
            ],
            "matchUpdateTypes": [
                "minor",
                "patch"
            ],
            "groupName": "all non-major dependencies",
            "groupSlug": "all-minor-patch"
        }
    ]
}
