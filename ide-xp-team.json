{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "github>SonarSource/renovate-config"
    ],
    "schedule": [
        "after 7am every weekday",
        "before 8pm every weekday"
    ],
    "dependencyDashboard": true,
    "vulnerabilityAlerts": {
        "enabled": true,
        "labels": [
            "security"
        ]
    },
    "osvVulnerabilityAlerts": true,
    "packageRules": [
        {
            "description": "Watch master builds from internal repos (SLCORE, SLLS, SLO#, SQVSROS, ...)",
            "matchDatasources": [
                "maven"
            ],
            "matchPackagePatterns": [
                "^org\\.sonarsource\\.sonarlint."
            ],
            "registryUrls": [
                "https://repox.jfrog.io/artifactory/sonarsource-builds"
            ]
        },
        {
            "description": "Wait for 5 days after a release before updating to avoid early bugs",
            "matchUpdateTypes": [
                "patch",
                "minor",
                "major"
            ],
            "minimumReleaseAge": "5 days"
        },
        {
            "description": "Apply security upgrades immediately, without waiting",
            "isVulnerabilityAlert": true,
            "minimumReleaseAge": "0 days"
        },
        {
            "description": "Group all minor and patch updates in a single PR to reduce noise",
            "matchUpdateTypes": [
                "patch",
                "minor"
            ],
            "groupName": "all minor and patch updates",
            "groupSlug": "all-minor-patch"
        },
        {
            "description": "Group all GitHub Actions in the same PR",
            "matchManagers": [
                "github-actions"
            ],
            "groupName": "github actions",
            "groupSlug": "github-actions",
            "pinDigests": true
        }
    ]
}
