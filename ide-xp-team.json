{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "github>SonarSource/renovate-config"
    ],
    "schedule": [
        "after 7am every weekday",
        "before 7pm every weekday"
    ],
    "dependencyDashboard": true,
    "configMigration": true,
    "rebaseWhen": "conflicted",
    "prConcurrentLimit": 10,
    "addLabels": [
        "renovate-dependencies"
    ],
    "vulnerabilityAlerts": {
        "enabled": true,
        "labels": [
            "security"
        ]
    },
    "osvVulnerabilityAlerts": true,
    "packageRules": [
        {
            "description": "Ignore Java runtime version updates (managed manually)",
            "matchDepNames": [
                "java"
            ],
            "enabled": false
        },
        {
            "description": "Throttle mise updates: releases daily (CalVer), open a PR at most once a month",
            "matchDepNames": [
                "mise"
            ],
            "schedule": [
                "on the first day of the month"
            ]
        },
        {
            "description": "Group all GitHub Actions in the same PR with SHA pinning",
            "matchManagers": [
                "github-actions"
            ],
            "groupName": "github actions",
            "groupSlug": "github-actions",
            "pinDigests": true
        }
    ]
}
