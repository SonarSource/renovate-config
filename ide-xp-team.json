{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "github>SonarSource/renovate-config"
    ],
    "schedule": [
        "after 7am every weekday",
        "before 7pm every weekday"
    ],
    "dependencyDashboard": true,
    "vulnerabilityAlerts": {
        "enabled": true,
        "labels": [
            "security"
        ]
    },
    "osvVulnerabilityAlerts": true,
    "packageRules": [
        {
            "description": "Group all SonarLint Core (SLCORE) packages in a dedicated PR (released versions only)",
            "matchDatasources": [
                "maven"
            ],
            "matchPackagePatterns": [
                "^org\\.sonarsource\\.sonarlint\\.core:"
            ],
            "matchUpdateTypes": [
                "patch",
                "minor",
                "major"
            ],
            "groupName": "SonarLint Core dependencies",
            "groupSlug": "sonarlint-core-dependencies"
        },
        {
            "description": "Group all analyzer packages in a dedicated PR (excludes SLCORE)",
            "matchDatasources": [
                "maven"
            ],
            "matchPackagePatterns": [
                "^org\\.sonarsource\\.",
                "^com\\.sonarsource\\."
            ],
            "excludePackagePatterns": [
                "^org\\.sonarsource\\.sonarlint\\.core:"
            ],
            "matchUpdateTypes": [
                "patch",
                "minor",
                "major"
            ],
            "groupName": "analyzer dependencies",
            "groupSlug": "analyzer-dependencies"
        },
        {
            "description": "Group all minor and patch updates in a single PR to reduce noise (excludes analyzers and SLCORE)",
            "matchUpdateTypes": [
                "patch",
                "minor"
            ],
            "excludePackagePatterns": [
                "^org\\.sonarsource\\.",
                "^com\\.sonarsource\\."
            ],
            "groupName": "all minor and patch updates",
            "groupSlug": "all-minor-patch"
        },
        {
            "description": "Group all GitHub Actions in the same PR",
            "matchManagers": [
                "github-actions"
            ],
            "groupName": "github actions",
            "groupSlug": "github-actions",
            "pinDigests": true
        }
    ]
}
